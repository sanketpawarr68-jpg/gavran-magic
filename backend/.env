# =====================================================
# Firebase Admin SDK (for backend token verification)
# Get from: Firebase Console → Project Settings
#           → Service accounts → Generate new private key
# Download the JSON file and either:
# Option A: Set FIREBASE_SERVICE_ACCOUNT_PATH to the JSON file path
# Option B: Copy each value from the JSON into the vars below
# =====================================================
FIREBASE_SERVICE_ACCOUNT_PATH=

# OR paste individual values from the service account JSON:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id

